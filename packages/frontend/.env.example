# Frontend Environment Variables
# Copy this file to .env.local and set appropriate values for your deployment

# REQUIRED: Application timezone (IANA timezone identifier)
# Examples: Australia/Sydney, America/New_York, Europe/London, Asia/Tokyo
VITE_TIMEZONE=Australia/Sydney

# REQUIRED: Default suburb/city name for the platform
# Used in SEO metadata and default displays
VITE_DEFAULT_SUBURB=Guildford

# REQUIRED: Platform name for branding
# Used in page titles, metadata, and throughout the UI
VITE_PLATFORM_NAME=Community Hub

# OPTIONAL: Base URL for the application (for canonical URLs)
# Default: current window.location.origin in browser
VITE_BASE_URL=https://example.com

# OPTIONAL: API base URL
# Default: /api/v1
VITE_API_BASE_URL=/api/v1
