generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model appeals {
  id                               String       @id
  user_id                          String
  content_type                     String       @db.VarChar(50)
  content_id                       String
  original_action                  String       @db.VarChar(100)
  reason                           String
  supporting_evidence              String[]
  status                           AppealStatus @default(PENDING)
  reviewer_id                      String?
  reviewer_notes                   String?
  created_at                       DateTime     @default(now())
  reviewed_at                      DateTime?
  users_appeals_reviewer_idTousers users?       @relation("appeals_reviewer_idTousers", fields: [reviewer_id], references: [id])
  users_appeals_user_idTousers     users        @relation("appeals_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade)

  @@index([reviewer_id])
  @@index([status])
  @@index([user_id])
}

model audit_logs {
  id             String    @id
  actor_id       String?
  actor_role     ActorRole
  action         String
  target_type    String
  target_id      String
  previous_value Json?
  new_value      Json?
  reason         String?
  ip_address     String
  user_agent     String
  created_at     DateTime  @default(now())
  users          users?    @relation(fields: [actor_id], references: [id])

  @@index([actor_id])
  @@index([created_at])
  @@index([target_type, target_id])
}

model business_analytics_daily {
  id                 String     @id
  business_id        String
  date               DateTime   @db.Date
  profile_views      Int        @default(0)
  unique_views       Int        @default(0)
  search_appearances Int        @default(0)
  website_clicks     Int        @default(0)
  phone_clicks       Int        @default(0)
  directions_clicks  Int        @default(0)
  photo_views        Int        @default(0)
  saves              Int        @default(0)
  reviews            Int        @default(0)
  messages           Int        @default(0)
  businesses         businesses @relation(fields: [business_id], references: [id], onDelete: Cascade)

  @@unique([business_id, date])
  @@index([business_id])
  @@index([date])
}

model business_analytics_events {
  id              String             @id
  business_id     String
  event_type      AnalyticsEventType
  user_id         String?
  session_id      String?            @db.VarChar(100)
  referral_source String?            @db.VarChar(50)
  search_term     String?            @db.VarChar(200)
  ip_address_hash String?            @db.VarChar(100)
  user_agent      String?            @db.VarChar(500)
  metadata        Json?
  event_date      DateTime           @default(now())
  businesses      businesses         @relation(fields: [business_id], references: [id], onDelete: Cascade)
  users           users?             @relation(fields: [user_id], references: [id])

  @@index([business_id, event_date])
  @@index([business_id, event_type])
  @@index([event_date])
  @@index([user_id])
}

model business_claim_requests {
  id                                                String                  @id
  business_id                                       String
  user_id                                           String
  verification_method                               VerificationMethod
  verification_status                               ClaimVerificationStatus @default(PENDING)
  claim_status                                      ClaimStatus             @default(PENDING)
  verification_code                                 String?
  verification_attempts                             Int                     @default(0)
  verification_expires_at                           DateTime?
  verification_token                                String?
  token_expires_at                                  DateTime?
  document_type                                     String?                 @db.VarChar(50)
  document_urls                                     String[]
  google_business_id                                String?
  google_access_token                               String?
  moderator_id                                      String?
  moderator_notes                                   String?
  decision_at                                       DateTime?
  rejection_reason                                  String?                 @db.VarChar(500)
  appealed_at                                       DateTime?
  appeal_reason                                     String?
  ip_address                                        String?                 @db.VarChar(45)
  user_agent                                        String?                 @db.VarChar(500)
  created_at                                        DateTime                @default(now())
  updated_at                                        DateTime
  businesses                                        businesses              @relation(fields: [business_id], references: [id], onDelete: Cascade)
  users_business_claim_requests_moderator_idTousers users?                  @relation("business_claim_requests_moderator_idTousers", fields: [moderator_id], references: [id])
  users_business_claim_requests_user_idTousers      users                   @relation("business_claim_requests_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([business_id, user_id])
  @@index([business_id])
  @@index([claim_status])
  @@index([created_at])
  @@index([user_id])
  @@index([verification_status])
}

model business_owner_staff {
  id                                         String     @id
  business_id                                String
  user_id                                    String
  role                                       String     @db.VarChar(50)
  permissions                                String[]
  added_by                                   String
  created_at                                 DateTime   @default(now())
  updated_at                                 DateTime
  users_business_owner_staff_added_byTousers users      @relation("business_owner_staff_added_byTousers", fields: [added_by], references: [id], onDelete: Cascade)
  businesses                                 businesses @relation(fields: [business_id], references: [id], onDelete: Cascade)
  users_business_owner_staff_user_idTousers  users      @relation("business_owner_staff_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([business_id, user_id])
  @@index([business_id])
  @@index([user_id])
}

model businesses {
  id                        String                      @id
  name                      String                      @db.VarChar(100)
  slug                      String                      @unique
  description               Json
  category_primary_id       String
  categories_secondary      String[]
  address                   Json
  phone                     String
  email                     String?
  website                   String?
  secondary_phone           String?
  operating_hours           Json?
  logo                      String?
  cover_photo               String?
  gallery                   Json?
  social_links              Json?
  languages_spoken          String[]                    @default([])
  certifications            String[]                    @default([])
  payment_methods           String[]                    @default([])
  accessibility_features    String[]                    @default([])
  price_range               PriceRange?
  parking_information       String?
  year_established          Int?
  status                    BusinessStatus              @default(PENDING)
  claimed                   Boolean                     @default(false)
  claimed_by                String?
  verified_at               DateTime?
  created_at                DateTime                    @default(now())
  updated_at                DateTime
  display_order             Int                         @default(0)
  featured                  Boolean                     @default(false)
  timezone                  String                      @default("Australia/Sydney") @db.VarChar(50)
  detailed_description      Json?
  menu_pdf_url              String?                     @db.VarChar(500)
  gbp_last_sync_at          DateTime?
  gbp_sync_status           String?                     @db.VarChar(20)
  business_analytics_daily  business_analytics_daily[]
  business_analytics_events business_analytics_events[]
  business_claim_requests   business_claim_requests[]
  business_owner_staff      business_owner_staff[]
  categories                categories                  @relation(fields: [category_primary_id], references: [id])
  users                     users?                      @relation(fields: [claimed_by], references: [id])
  conversations             conversations[]
  deals                     deals[]
  events                    events[]
  quick_reply_templates     quick_reply_templates[]
  reviews                   reviews[]
  saved_businesses          saved_businesses[]
  business_enquiries        business_enquiries[]
  social_accounts           social_accounts[]
  social_posts              social_posts[]

  @@index([category_primary_id])
  @@index([claimed])
  @@index([created_at(sort: Desc)])
  @@index([featured, display_order])
  @@index([status, created_at])
}

model business_enquiries {
  id              String    @id @default(uuid())
  business_id     String
  name            String    @db.VarChar(100)
  email           String    @db.VarChar(255)
  phone           String?   @db.VarChar(20)
  category        String    @default("GENERAL") @db.VarChar(30)
  subject         String    @db.VarChar(200)
  message         String    @db.Text
  status          String    @default("NEW") @db.VarChar(20)
  user_id         String?
  ip_address      String?   @db.VarChar(45)
  reply_message   String?   @db.Text
  replied_at      DateTime?
  call_count      Int       @default(0)
  last_called_at  DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  businesses      businesses @relation(fields: [business_id], references: [id], onDelete: Cascade)
  users           users?     @relation(fields: [user_id], references: [id])

  @@index([business_id, created_at(sort: Desc)])
  @@index([status])
}

model categories {
  id               String       @id
  type             CategoryType
  name             Json
  slug             String
  icon             String       @default("default")
  parent_id        String?
  display_order    Int          @default(0)
  active           Boolean      @default(true)
  created_at       DateTime     @default(now())
  updated_at       DateTime
  businesses       businesses[]
  categories       categories?  @relation("categoriesTocategories", fields: [parent_id], references: [id])
  other_categories categories[] @relation("categoriesTocategories")
  events           events[]

  @@unique([type, slug])
  @@index([type, active])
}

model deals {
  id             String       @id @default(uuid())
  business_id    String
  title          String       @db.VarChar(100)
  description    String       @db.VarChar(500)
  price          Decimal?     @db.Decimal(10, 2)
  original_price Decimal?     @db.Decimal(10, 2)
  discount_type  DiscountType?
  discount_value Decimal?     @db.Decimal(10, 2)
  duration       String?      @db.VarChar(100)
  voucher_code   String?      @db.VarChar(50)
  image          String?      @db.VarChar(500)
  terms          String?      @db.VarChar(500)
  valid_from     DateTime
  valid_until    DateTime
  featured       Boolean      @default(false)
  status          DealStatus   @default(ACTIVE)
  views           Int          @default(0)
  clicks          Int          @default(0)
  voucher_reveals Int          @default(0)
  created_at      DateTime     @default(now())
  updated_at     DateTime     @updatedAt

  businesses     businesses   @relation(fields: [business_id], references: [id], onDelete: Cascade)

  @@index([business_id])
  @@index([status, valid_until])
  @@index([featured, status])
}

model conversations {
  id                    String             @id
  business_id           String
  user_id               String
  subject               String             @db.VarChar(200)
  subject_category      SubjectCategory
  status                ConversationStatus @default(ACTIVE)
  last_message_at       DateTime?
  unread_count_business Int                @default(0)
  unread_count_user     Int                @default(0)
  created_at            DateTime           @default(now())
  updated_at            DateTime
  businesses            businesses         @relation(fields: [business_id], references: [id], onDelete: Cascade)
  users                 users              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  messages              messages[]

  @@unique([business_id, user_id])
  @@index([business_id])
  @@index([last_message_at])
  @@index([status])
  @@index([user_id])
}

model email_templates {
  id           String   @id
  template_key String   @unique
  name         String
  description  String
  subject      Json
  body_html    Json
  body_text    Json
  variables    String[]
  active       Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime
}

model event_rsvps {
  id          String     @id
  event_id    String
  user_id     String
  status      RSVPStatus
  guest_count Int        @default(1)
  notes       String?    @db.VarChar(200)
  rsvp_date   DateTime   @default(now())
  created_at  DateTime   @default(now())
  updated_at  DateTime
  events      events     @relation(fields: [event_id], references: [id], onDelete: Cascade)
  users       users      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([event_id, user_id])
  @@index([event_id])
  @@index([event_id, status])
  @@index([user_id])
}

model events {
  id                 String        @id
  title              String        @db.VarChar(100)
  description        String
  category_id        String
  start_time         DateTime
  end_time           DateTime
  timezone           String        @default("Australia/Sydney") @db.VarChar(50)
  location_type      LocationType
  venue              Json?
  online_url         String?       @db.VarChar(500)
  linked_business_id String?
  image_url          String?       @db.VarChar(500)
  ticket_url         String?       @db.VarChar(500)
  cost               String?       @db.VarChar(100)
  capacity           Int?
  age_restriction    String?       @db.VarChar(20)
  accessibility      String[]      @default([])
  recurrence         Json?
  created_by_id      String
  status             EventStatus   @default(PENDING)
  slug               String?       @db.VarChar(150)
  created_at         DateTime      @default(now())
  updated_at         DateTime
  event_rsvps        event_rsvps[]
  categories         categories    @relation(fields: [category_id], references: [id])
  users              users         @relation(fields: [created_by_id], references: [id], onDelete: Cascade)
  businesses         businesses?   @relation(fields: [linked_business_id], references: [id])

  @@index([category_id])
  @@index([created_by_id])
  @@index([linked_business_id])
  @@index([location_type, start_time])
  @@index([slug])
  @@index([start_time])
  @@index([status, start_time])
}

model message_attachments {
  id         String   @id
  message_id String
  url        String   @db.VarChar(500)
  alt_text   String?  @db.VarChar(200)
  size_bytes Int
  mime_type  String   @db.VarChar(50)
  created_at DateTime @default(now())
  messages   messages @relation(fields: [message_id], references: [id], onDelete: Cascade)

  @@index([message_id])
}

model messages {
  id                  String                @id
  conversation_id     String
  sender_type         SenderType
  sender_id           String
  content             String
  read_at             DateTime?
  deleted_at          DateTime?
  created_at          DateTime              @default(now())
  message_attachments message_attachments[]
  conversations       conversations         @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@index([conversation_id])
  @@index([created_at])
  @@index([sender_id])
}

model moderation_reports {
  id                                           String            @id
  reporter_id                                  String
  content_type                                 ContentType
  content_id                                   String
  reason                                       ReportReason
  details                                      String?           @db.VarChar(500)
  status                                       ModerationStatus  @default(PENDING)
  moderator_id                                 String?
  moderator_notes                              String?
  action_taken                                 ModerationAction?
  created_at                                   DateTime          @default(now())
  reviewed_at                                  DateTime?
  reviews                                      reviews           @relation(fields: [content_id], references: [id], onDelete: Cascade)
  users_moderation_reports_moderator_idTousers users?            @relation("moderation_reports_moderator_idTousers", fields: [moderator_id], references: [id])
  users_moderation_reports_reporter_idTousers  users             @relation("moderation_reports_reporter_idTousers", fields: [reporter_id], references: [id], onDelete: Cascade)

  @@index([content_type, content_id])
  @@index([moderator_id])
  @@index([reporter_id])
  @@index([status])
}

model quick_reply_templates {
  id          String     @id
  business_id String
  name        String     @db.VarChar(50)
  content     String
  order       Int        @default(0)
  created_at  DateTime   @default(now())
  updated_at  DateTime
  businesses  businesses @relation(fields: [business_id], references: [id], onDelete: Cascade)

  @@index([business_id])
}

model review_helpful {
  id         String   @id
  review_id  String
  user_id    String
  created_at DateTime @default(now())
  reviews    reviews  @relation(fields: [review_id], references: [id], onDelete: Cascade)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([review_id, user_id])
  @@index([review_id])
  @@index([user_id])
}

model review_photos {
  id         String   @id
  review_id  String
  url        String   @db.VarChar(500)
  alt_text   String   @db.VarChar(200)
  order      Int      @default(0)
  created_at DateTime @default(now())
  reviews    reviews  @relation(fields: [review_id], references: [id], onDelete: Cascade)

  @@index([review_id])
}

model reviews {
  id                   String               @id
  business_id          String
  user_id              String
  rating               Int                  @db.SmallInt
  title                String?              @db.VarChar(100)
  content              String
  language             String               @default("en") @db.VarChar(10)
  helpful_count        Int                  @default(0)
  status               ReviewStatus         @default(PENDING)
  moderation_notes     String?
  business_response    String?              @db.VarChar(500)
  business_response_at DateTime?
  created_at           DateTime             @default(now())
  updated_at           DateTime
  published_at         DateTime?
  moderation_reports   moderation_reports[]
  review_helpful       review_helpful[]
  review_photos        review_photos[]
  businesses           businesses           @relation(fields: [business_id], references: [id], onDelete: Cascade)
  users                users                @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, business_id])
  @@index([business_id])
  @@index([created_at])
  @@index([helpful_count])
  @@index([status])
  @@index([user_id])
}

model saved_businesses {
  id          String       @id
  user_id     String
  business_id String
  list_id     String?
  notes       String?      @db.VarChar(500)
  created_at  DateTime     @default(now())
  businesses  businesses   @relation(fields: [business_id], references: [id], onDelete: Cascade)
  saved_lists saved_lists? @relation(fields: [list_id], references: [id])
  users       users        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, business_id])
  @@index([business_id])
  @@index([list_id])
  @@index([user_id])
}

model saved_lists {
  id               String             @id
  user_id          String
  name             String             @db.VarChar(50)
  is_default       Boolean            @default(false)
  created_at       DateTime           @default(now())
  updated_at       DateTime
  saved_businesses saved_businesses[]
  users            users              @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([user_id, is_default])
}

model system_settings {
  key         String   @id
  value       Json
  description String
  updated_by  String?
  updated_at  DateTime
}

model user_sessions {
  id             String   @id
  user_id        String
  token_hash     String   @unique
  device_info    Json
  ip_address     String
  location       String?
  is_current     Boolean  @default(false)
  last_active_at DateTime
  expires_at     DateTime
  created_at     DateTime @default(now())
  users          users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([expires_at])
  @@index([user_id])
}

model users {
  id                                                                  String                      @id
  email                                                               String                      @unique
  password_hash                                                       String
  display_name                                                        String
  profile_photo                                                       String?
  language_preference                                                 String                      @default("en")
  suburb                                                              String?
  bio                                                                 String?                     @db.VarChar(500)
  interests                                                           String[]
  notification_preferences                                            Json?
  receive_deal_emails                                                 Boolean                     @default(false)
  receive_event_emails                                                Boolean                     @default(false)
  role                                                                UserRole                    @default(COMMUNITY)
  status                                                              UserStatus                  @default(PENDING)
  email_verified                                                      Boolean                     @default(false)
  pending_email                                                       String?
  deletion_requested_at                                               DateTime?
  created_at                                                          DateTime                    @default(now())
  updated_at                                                          DateTime
  last_login                                                          DateTime?
  appeals_appeals_reviewer_idTousers                                  appeals[]                   @relation("appeals_reviewer_idTousers")
  appeals_appeals_user_idTousers                                      appeals[]                   @relation("appeals_user_idTousers")
  audit_logs                                                          audit_logs[]
  business_analytics_events                                           business_analytics_events[]
  business_claim_requests_business_claim_requests_moderator_idTousers business_claim_requests[]   @relation("business_claim_requests_moderator_idTousers")
  business_claim_requests_business_claim_requests_user_idTousers      business_claim_requests[]   @relation("business_claim_requests_user_idTousers")
  business_owner_staff_business_owner_staff_added_byTousers           business_owner_staff[]      @relation("business_owner_staff_added_byTousers")
  business_owner_staff_business_owner_staff_user_idTousers            business_owner_staff[]      @relation("business_owner_staff_user_idTousers")
  businesses                                                          businesses[]
  conversations                                                       conversations[]
  event_rsvps                                                         event_rsvps[]
  events                                                              events[]
  moderation_reports_moderation_reports_moderator_idTousers           moderation_reports[]        @relation("moderation_reports_moderator_idTousers")
  moderation_reports_moderation_reports_reporter_idTousers            moderation_reports[]        @relation("moderation_reports_reporter_idTousers")
  review_helpful                                                      review_helpful[]
  reviews                                                             reviews[]
  saved_businesses                                                    saved_businesses[]
  saved_lists                                                         saved_lists[]
  user_sessions                                                       user_sessions[]
  business_enquiries                                                  business_enquiries[]
  social_accounts                                                     social_accounts[]
  social_posts_created                                                social_posts[]
}

enum ActorRole {
  USER
  BUSINESS_OWNER
  MODERATOR
  ADMIN
  SYSTEM
}

enum AnalyticsEventType {
  PROFILE_VIEW
  SEARCH_APPEARANCE
  WEBSITE_CLICK
  PHONE_CLICK
  DIRECTIONS_CLICK
  PHOTO_VIEW
  SAVE
  UNSAVE
  REVIEW_CREATED
  MESSAGE_SENT
}

enum AppealStatus {
  PENDING
  UPHELD
  REJECTED
}

enum BusinessStatus {
  ACTIVE
  PENDING
  SUSPENDED
  DELETED
}

enum CategoryType {
  BUSINESS
  EVENT
  DEAL
  NOTICE
  GROUP
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
  APPEALED
}

enum ClaimVerificationStatus {
  PENDING
  VERIFIED
  FAILED
  EXPIRED
}

enum ContentType {
  REVIEW
  NOTICE
  MESSAGE
  BUSINESS
  EVENT
}

enum DealStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum DiscountType {
  PERCENTAGE
  FIXED
  BOGO
  FREE_ITEM
}

enum ConversationStatus {
  ACTIVE
  ARCHIVED
  BLOCKED
}

enum EventStatus {
  PENDING
  ACTIVE
  CANCELLED
  PAST
}

enum LocationType {
  PHYSICAL
  ONLINE
  HYBRID
}

enum ModerationAction {
  NONE
  WARNING
  CONTENT_REMOVED
  USER_SUSPENDED
}

enum ModerationStatus {
  PENDING
  REVIEWED
  ACTIONED
  DISMISSED
}

enum PriceRange {
  BUDGET
  MODERATE
  PREMIUM
  LUXURY
}

enum RSVPStatus {
  GOING
  INTERESTED
  NOT_GOING
}

enum RecurrenceFrequency {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum ReportReason {
  SPAM
  INAPPROPRIATE
  FAKE
  HARASSMENT
  OTHER
}

enum ReviewStatus {
  PENDING
  PUBLISHED
  HIDDEN
  DELETED
}

enum SenderType {
  USER
  BUSINESS
}

enum SubjectCategory {
  GENERAL
  PRODUCT_QUESTION
  BOOKING
  FEEDBACK
  OTHER
}

enum UserRole {
  COMMUNITY
  BUSINESS_OWNER
  MODERATOR
  CURATOR
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
  DELETED
}

enum VerificationMethod {
  PHONE
  EMAIL
  DOCUMENT
  GOOGLE_BUSINESS
}

enum SocialPlatform {
  FACEBOOK
  INSTAGRAM
  TWITTER
  LINKEDIN
  GOOGLE_BUSINESS
}

enum SocialPostStatus {
  PENDING
  QUEUED
  PUBLISHING
  PUBLISHED
  FAILED
  CANCELLED
}

model social_accounts {
  id                       String              @id @default(uuid())
  business_id              String
  platform                 SocialPlatform
  platform_account_id      String              @db.VarChar(255)
  platform_account_name    String              @db.VarChar(255)
  access_token_encrypted   String
  refresh_token_encrypted  String?
  token_expires_at         DateTime?
  scopes                   String[]            @default([])
  connected_by             String
  is_active                Boolean             @default(true)
  last_post_at             DateTime?
  last_error               String?             @db.VarChar(500)
  created_at               DateTime            @default(now())
  updated_at               DateTime            @updatedAt

  businesses               businesses          @relation(fields: [business_id], references: [id], onDelete: Cascade)
  users                    users               @relation(fields: [connected_by], references: [id])
  social_posts             social_posts[]

  @@unique([business_id, platform])
  @@index([business_id])
  @@index([connected_by])
  @@index([token_expires_at])
}

model social_posts {
  id                  String           @id @default(uuid())
  business_id         String
  social_account_id   String
  content_type        String           @db.VarChar(20)
  content_id          String
  platform            SocialPlatform
  caption             String           @db.VarChar(2200)
  image_url           String?          @db.VarChar(500)
  platform_post_id    String?          @db.VarChar(255)
  platform_post_url   String?          @db.VarChar(500)
  status              SocialPostStatus @default(PENDING)
  scheduled_at        DateTime?
  published_at        DateTime?
  error_message       String?          @db.VarChar(1000)
  retry_count         Int              @default(0)
  max_retries         Int              @default(3)
  created_by          String
  created_at          DateTime         @default(now())
  updated_at          DateTime         @updatedAt

  businesses          businesses       @relation(fields: [business_id], references: [id], onDelete: Cascade)
  social_accounts     social_accounts  @relation(fields: [social_account_id], references: [id], onDelete: Cascade)
  users               users            @relation(fields: [created_by], references: [id])
  social_post_logs    social_post_logs[]

  @@index([business_id])
  @@index([social_account_id])
  @@index([content_type, content_id])
  @@index([status, scheduled_at])
  @@index([platform, status])
}

model social_post_logs {
  id              String       @id @default(uuid())
  social_post_id  String
  action          String       @db.VarChar(50)
  details         Json?
  created_at      DateTime     @default(now())

  social_posts    social_posts @relation(fields: [social_post_id], references: [id], onDelete: Cascade)

  @@index([social_post_id])
  @@index([created_at])
}
