generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum UserRole {
  COMMUNITY
  BUSINESS_OWNER
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
  DELETED
}

enum CategoryType {
  BUSINESS
  EVENT
  DEAL
  NOTICE
  GROUP
}

enum ActorRole {
  USER
  BUSINESS_OWNER
  MODERATOR
  ADMIN
  SYSTEM
}

enum BusinessStatus {
  ACTIVE
  PENDING
  SUSPENDED
  DELETED
}

enum PriceRange {
  BUDGET
  MODERATE
  PREMIUM
  LUXURY
}

/// Phase 6: Review status enum
enum ReviewStatus {
  PENDING
  PUBLISHED
  HIDDEN
  DELETED
}

/// Phase 6: Content type for moderation
enum ContentType {
  REVIEW
  NOTICE
  MESSAGE
  BUSINESS
  EVENT
}

/// Phase 6: Moderation report reason
enum ReportReason {
  SPAM
  INAPPROPRIATE
  FAKE
  HARASSMENT
  OTHER
}

/// Phase 6: Moderation status
enum ModerationStatus {
  PENDING
  REVIEWED
  ACTIONED
  DISMISSED
}

/// Phase 6: Moderation action taken
enum ModerationAction {
  NONE
  WARNING
  CONTENT_REMOVED
  USER_SUSPENDED
}

/// Phase 6: Appeal status
enum AppealStatus {
  PENDING
  UPHELD
  REJECTED
}

// ─── Phase 7 Enums ──────────────────────────────────────────

/// Phase 7: Verification method for business claims
enum VerificationMethod {
  PHONE
  EMAIL
  DOCUMENT
  GOOGLE_BUSINESS
}

/// Phase 7: Status of claim verification step
enum ClaimVerificationStatus {
  PENDING
  VERIFIED
  FAILED
  EXPIRED
}

/// Phase 7: Overall claim status
enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
  APPEALED
}

/// Phase 7: Analytics event types
enum AnalyticsEventType {
  PROFILE_VIEW
  SEARCH_APPEARANCE
  WEBSITE_CLICK
  PHONE_CLICK
  DIRECTIONS_CLICK
  PHOTO_VIEW
  SAVE
  UNSAVE
  FOLLOW
  UNFOLLOW
  REVIEW_CREATED
  MESSAGE_SENT
}

// ─── Models ──────────────────────────────────────────────

/// Spec A.2 - Platform user accounts
/// Note: `status` defaults to PENDING (not ACTIVE) intentionally -- new users must
/// verify their email before becoming active. This is a security-driven deviation
/// from the spec's enumeration order. See Spec Section 4.5 (email verification).
model User {
  id                      String     @id @default(uuid())
  email                   String     @unique
  passwordHash            String     @map("password_hash")
  displayName             String     @map("display_name")
  profilePhoto            String?    @map("profile_photo")
  languagePreference      String     @default("en") @map("language_preference")
  suburb                  String?
  bio                     String?    @db.VarChar(500)
  interests               String[]
  notificationPreferences Json?      @map("notification_preferences")
  role                    UserRole   @default(COMMUNITY)
  status                  UserStatus @default(PENDING)
  emailVerified           Boolean    @default(false) @map("email_verified")
  pendingEmail            String?    @map("pending_email")
  deletionRequestedAt     DateTime?  @map("deletion_requested_at")
  createdAt               DateTime   @default(now()) @map("created_at")
  updatedAt               DateTime   @updatedAt @map("updated_at")
  lastLogin               DateTime?  @map("last_login")

  sessions        UserSession[]
  auditLogs       AuditLog[]
  ownedBusinesses Business[]

  // Phase 6: User Engagement Features
  savedBusinesses  SavedBusiness[]
  savedLists       SavedList[]
  reviews          Review[]
  reviewsHelpful   ReviewHelpful[]
  following        BusinessFollow[]
  reportsSubmitted ModerationReport[] @relation("ReportedBy")
  reportsModerated ModerationReport[] @relation("ModeratedBy")
  appealsSubmitted Appeal[]           @relation("AppealedBy")
  appealsReviewed  Appeal[]           @relation("AppealReviewedBy")

  // Phase 7: Business Owner Features
  claimRequests     BusinessClaimRequest[]   @relation("ClaimRequests")
  claimsModeratored BusinessClaimRequest[]   @relation("ClaimModerator")
  analyticsEvents   BusinessAnalyticsEvent[] @relation("AnalyticsEvents")
  staffMemberships  BusinessOwnerStaff[]     @relation("StaffMember")
  staffAdded        BusinessOwnerStaff[]     @relation("StaffAddedBy")

  @@map("users")
}

/// Spec A.14 - Hierarchical taxonomy for businesses, events, deals, etc.
model Category {
  id           String       @id @default(uuid())
  type         CategoryType
  name         Json // Multilingual: {"en": "Restaurant", "ar": "مطعم"}
  slug         String
  icon         String       @default("default")
  parentId     String?      @map("parent_id")
  parent       Category?    @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children     Category[]   @relation("CategoryHierarchy")
  displayOrder Int          @default(0) @map("display_order")
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  businesses Business[] @relation("BusinessPrimaryCategory")

  @@unique([type, slug])
  @@index([type, active])
  @@map("categories")
}

/// Spec A.1 - Business entity for directory
model Business {
  id                  String  @id @default(uuid())
  name                String  @db.VarChar(100)
  slug                String  @unique
  description         Json // Multilingual: {"en": "...", "ar": "..."} (short, 500 chars)
  detailedDescription Json?   @map("detailed_description") // Multilingual: rich text, 2000 chars
  menuPdfUrl          String? @map("menu_pdf_url") @db.VarChar(500) // Menu/price list PDF

  // Categories
  categoryPrimaryId   String   @map("category_primary_id")
  categoryPrimary     Category @relation("BusinessPrimaryCategory", fields: [categoryPrimaryId], references: [id], onDelete: Restrict)
  categoriesSecondary String[] @map("categories_secondary") // Array of category IDs (max 3)

  // Location (embedded as JSON)
  address Json // {street, suburb, state, postcode, country, latitude, longitude}

  // Contact
  phone          String
  email          String?
  website        String?
  secondaryPhone String? @map("secondary_phone")

  // Hours (embedded as JSON)
  operatingHours Json? @map("operating_hours") // {monday: {open, close, closed, byAppointment}, ...}

  // Media
  logo       String?
  coverPhoto String? @map("cover_photo")
  gallery    Json? // Array of {url, alt, category, order}

  // Social (embedded as JSON)
  socialLinks Json? @map("social_links") // {facebook, instagram, twitter, tiktok, linkedin, youtube, googleBusiness}

  // Business Info
  languagesSpoken       String[] @default([]) @map("languages_spoken")
  certifications        String[] @default([])
  paymentMethods        String[] @default([]) @map("payment_methods")
  accessibilityFeatures String[] @default([]) @map("accessibility_features")

  // Optional Fields
  priceRange         PriceRange? @map("price_range")
  parkingInformation String?     @map("parking_information")
  yearEstablished    Int?        @map("year_established")

  // Status & Ownership
  status        BusinessStatus @default(PENDING)
  claimed       Boolean        @default(false)
  claimedBy     String?        @map("claimed_by")
  claimedByUser User?          @relation(fields: [claimedBy], references: [id], onDelete: SetNull)
  verifiedAt    DateTime?      @map("verified_at")

  // Phase 5: Search & Discovery Fields
  timezone     String  @default("Australia/Sydney") @db.VarChar(50)
  featured     Boolean @default(false)
  displayOrder Int     @default(0) @map("display_order")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Phase 6: User Engagement Features
  savedBy   SavedBusiness[]
  reviews   Review[]
  followers BusinessFollow[]

  // Phase 7: Business Owner Features
  claimRequests   BusinessClaimRequest[]
  analyticsEvents BusinessAnalyticsEvent[]
  analyticsDaily  BusinessAnalyticsDaily[]
  staff           BusinessOwnerStaff[]

  @@index([status, createdAt])
  @@index([categoryPrimaryId])
  @@index([claimed])
  @@index([featured, displayOrder])
  @@index([createdAt(sort: Desc)])
  @@map("businesses")
}

/// Spec A.17 - Active user sessions for security audit
model UserSession {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash    String   @unique @map("token_hash")
  deviceInfo   Json     @map("device_info") // {user_agent, device_type, os, browser}
  ipAddress    String   @map("ip_address")
  location     String? // city/country from IP geolocation
  isCurrent    Boolean  @default(false) @map("is_current")
  lastActiveAt DateTime @map("last_active_at")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("user_sessions")
}

/// Spec A.18 - Immutable audit trail (7-year retention)
model AuditLog {
  id            String    @id @default(uuid())
  actorId       String?   @map("actor_id")
  actor         User?     @relation(fields: [actorId], references: [id], onDelete: SetNull)
  actorRole     ActorRole @map("actor_role")
  action        String // e.g. "review.delete", "user.suspend"
  targetType    String    @map("target_type") // e.g. "Review", "User"
  targetId      String    @map("target_id")
  previousValue Json?     @map("previous_value")
  newValue      Json?     @map("new_value")
  reason        String?
  ipAddress     String    @map("ip_address")
  userAgent     String    @map("user_agent")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

/// Spec A.19 - Multilingual email templates (runtime-editable)
model EmailTemplate {
  id          String   @id @default(uuid())
  templateKey String   @unique @map("template_key") // e.g. "welcome", "password_reset"
  name        String
  description String
  subject     Json // Multilingual: {"en": "Welcome!", "ar": "..."}
  bodyHtml    Json     @map("body_html") // Multilingual HTML
  bodyText    Json     @map("body_text") // Multilingual plain text
  variables   String[] // ["userName", "verificationLink"]
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("email_templates")
}

/// Spec A.24 - Runtime-editable platform settings
model SystemSetting {
  key         String   @id
  value       Json
  description String
  updatedBy   String?  @map("updated_by")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

// ─── Phase 6: User Engagement Features ────────────────────

/// Spec A.16 - User's saved businesses
model SavedBusiness {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  businessId String   @map("business_id")
  listId     String?  @map("list_id")
  notes      String?  @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at")

  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  list     SavedList? @relation(fields: [listId], references: [id], onDelete: SetNull)

  @@unique([userId, businessId])
  @@index([userId])
  @@index([businessId])
  @@index([listId])
  @@map("saved_businesses")
}

/// Spec A.16 - User's custom lists for organizing saved businesses
model SavedList {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String   @db.VarChar(50)
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedBusinesses SavedBusiness[]

  @@index([userId])
  @@index([userId, isDefault])
  @@map("saved_lists")
}

/// Spec A.4 - Business reviews with ratings and photos
model Review {
  id                 String       @id @default(uuid())
  businessId         String       @map("business_id")
  userId             String       @map("user_id")
  rating             Int          @db.SmallInt // 1-5
  title              String?      @db.VarChar(100)
  content            String       @db.Text // 50-1000 chars (validated in code)
  language           String       @default("en") @db.VarChar(10) // ISO 639-1
  helpfulCount       Int          @default(0) @map("helpful_count")
  status             ReviewStatus @default(PENDING)
  moderationNotes    String?      @map("moderation_notes") @db.Text
  businessResponse   String?      @map("business_response") @db.VarChar(500)
  businessResponseAt DateTime?    @map("business_response_at")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")
  publishedAt        DateTime?    @map("published_at")

  business Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  photos   ReviewPhoto[]
  helpful  ReviewHelpful[]
  reports  ModerationReport[]

  @@unique([userId, businessId])
  @@index([businessId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([helpfulCount])
  @@map("reviews")
}

/// Spec A.4 - Photos attached to reviews
model ReviewPhoto {
  id        String   @id @default(uuid())
  reviewId  String   @map("review_id")
  url       String   @db.VarChar(500)
  altText   String   @map("alt_text") @db.VarChar(200)
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@map("review_photos")
}

/// Spec A.4 - Track helpful votes on reviews
model ReviewHelpful {
  id        String   @id @default(uuid())
  reviewId  String   @map("review_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
  @@index([reviewId])
  @@index([userId])
  @@map("review_helpful")
}

/// Spec A.23 - Users following businesses
model BusinessFollow {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  businessId String   @map("business_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@index([userId])
  @@index([businessId])
  @@map("business_follows")
}

/// Spec A.22 - Content moderation reports
model ModerationReport {
  id             String            @id @default(uuid())
  reporterId     String            @map("reporter_id")
  contentType    ContentType       @map("content_type")
  contentId      String            @map("content_id")
  reason         ReportReason
  details        String?           @db.VarChar(500)
  status         ModerationStatus  @default(PENDING)
  moderatorId    String?           @map("moderator_id")
  moderatorNotes String?           @map("moderator_notes") @db.Text
  actionTaken    ModerationAction? @map("action_taken")
  createdAt      DateTime          @default(now()) @map("created_at")
  reviewedAt     DateTime?         @map("reviewed_at")

  reporter  User    @relation("ReportedBy", fields: [reporterId], references: [id], onDelete: Cascade)
  moderator User?   @relation("ModeratedBy", fields: [moderatorId], references: [id], onDelete: SetNull)
  review    Review? @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([contentType, contentId])
  @@index([reporterId])
  @@index([moderatorId])
  @@map("moderation_reports")
}

/// Spec A.22 - Appeals for moderation decisions
model Appeal {
  id                 String       @id @default(uuid())
  userId             String       @map("user_id")
  contentType        String       @map("content_type") @db.VarChar(50)
  contentId          String       @map("content_id")
  originalAction     String       @map("original_action") @db.VarChar(100)
  reason             String       @db.Text // max 1000 chars
  supportingEvidence String[]     @map("supporting_evidence") // Array of file URLs
  status             AppealStatus @default(PENDING)
  reviewerId         String?      @map("reviewer_id")
  reviewerNotes      String?      @map("reviewer_notes") @db.Text
  createdAt          DateTime     @default(now()) @map("created_at")
  reviewedAt         DateTime?    @map("reviewed_at")

  user     User  @relation("AppealedBy", fields: [userId], references: [id], onDelete: Cascade)
  reviewer User? @relation("AppealReviewedBy", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([reviewerId])
  @@map("appeals")
}

// ─── Phase 7: Business Owner Features ────────────────────────

/// Spec §13.1 - Business claim requests and verification tracking
model BusinessClaimRequest {
  id                 String                  @id @default(uuid())
  businessId         String                  @map("business_id")
  userId             String                  @map("user_id")
  verificationMethod VerificationMethod      @map("verification_method")
  verificationStatus ClaimVerificationStatus @default(PENDING) @map("verification_status")
  claimStatus        ClaimStatus             @default(PENDING) @map("claim_status")

  // Phone verification
  verificationCode      String?   @map("verification_code") // bcrypt hashed PIN
  verificationAttempts  Int       @default(0) @map("verification_attempts")
  verificationExpiresAt DateTime? @map("verification_expires_at")

  // Email verification
  verificationToken String?   @map("verification_token") // JWT token
  tokenExpiresAt    DateTime? @map("token_expires_at")

  // Document verification
  documentType String?  @map("document_type") @db.VarChar(50) // 'abn' | 'utility_bill' | 'business_registration'
  documentUrls String[] @map("document_urls")

  // Google Business verification
  googleBusinessId  String? @map("google_business_id")
  googleAccessToken String? @map("google_access_token") // Encrypted

  // Moderation
  moderatorId     String?   @map("moderator_id")
  moderatorNotes  String?   @map("moderator_notes") @db.Text
  decisionAt      DateTime? @map("decision_at")
  rejectionReason String?   @map("rejection_reason") @db.VarChar(500)

  // Appeal tracking
  appealedAt   DateTime? @map("appealed_at")
  appealReason String?   @map("appeal_reason") @db.Text

  // Audit fields
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  business  Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user      User     @relation("ClaimRequests", fields: [userId], references: [id], onDelete: Cascade)
  moderator User?    @relation("ClaimModerator", fields: [moderatorId], references: [id], onDelete: SetNull)

  @@unique([businessId, userId])
  @@index([businessId])
  @@index([userId])
  @@index([claimStatus])
  @@index([verificationStatus])
  @@index([createdAt])
  @@map("business_claim_requests")
}

/// Spec §13.4 - Analytics event tracking for business performance metrics
model BusinessAnalyticsEvent {
  id             String             @id @default(uuid())
  businessId     String             @map("business_id")
  eventType      AnalyticsEventType @map("event_type")
  userId         String?            @map("user_id") // null for anonymous
  sessionId      String?            @map("session_id") @db.VarChar(100) // for unique view tracking
  referralSource String?            @map("referral_source") @db.VarChar(50) // 'search' | 'homepage' | 'saved_list' | 'direct' | 'external'
  searchTerm     String?            @map("search_term") @db.VarChar(200) // if from search
  ipAddressHash  String?            @map("ip_address_hash") @db.VarChar(100) // bcrypt hashed, anonymized after 90 days
  userAgent      String?            @map("user_agent") @db.VarChar(500)
  metadata       Json? // Additional event-specific data
  eventDate      DateTime           @default(now()) @map("event_date")

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User?    @relation("AnalyticsEvents", fields: [userId], references: [id], onDelete: SetNull)

  @@index([businessId, eventDate])
  @@index([businessId, eventType])
  @@index([eventDate])
  @@index([userId])
  @@map("business_analytics_events")
}

/// Spec §13.4 - Aggregated daily analytics for faster queries
model BusinessAnalyticsDaily {
  id                String   @id @default(uuid())
  businessId        String   @map("business_id")
  date              DateTime @db.Date
  profileViews      Int      @default(0) @map("profile_views")
  uniqueViews       Int      @default(0) @map("unique_views")
  searchAppearances Int      @default(0) @map("search_appearances")
  websiteClicks     Int      @default(0) @map("website_clicks")
  phoneClicks       Int      @default(0) @map("phone_clicks")
  directionsClicks  Int      @default(0) @map("directions_clicks")
  photoViews        Int      @default(0) @map("photo_views")
  saves             Int      @default(0)
  follows           Int      @default(0)
  reviews           Int      @default(0)
  messages          Int      @default(0)

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, date])
  @@index([businessId])
  @@index([date])
  @@map("business_analytics_daily")
}

/// Spec §13 - Staff accounts for business owners (future feature)
model BusinessOwnerStaff {
  id          String   @id @default(uuid())
  businessId  String   @map("business_id")
  userId      String   @map("user_id")
  role        String   @db.VarChar(50) // 'manager' | 'staff' | 'viewer'
  permissions String[] // Array of permission flags
  addedBy     String   @map("added_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user        User     @relation("StaffMember", fields: [userId], references: [id], onDelete: Cascade)
  addedByUser User     @relation("StaffAddedBy", fields: [addedBy], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
  @@index([businessId])
  @@index([userId])
  @@map("business_owner_staff")
}
